            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>bool_HasChildren</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
