        <locationX>1200</locationX>
        <locationY>1700</locationY>
        <assignmentItems>
            <assignToReference>var_GroupSum</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Spec_Enrollments.hed__Credits_Earned__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txt_UsedEnrollmentIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>;</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txt_UsedEnrollmentIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Spec_Enrollments.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Children_Reqs</targetReference>
        </connector>
    </assignments>

    <assignments>
        <name>Assign_Used_Free</name>
        <label>Mark Used Free</label>
        <locationX>1000</locationX>
        <locationY>2100</locationY>
        <assignmentItems>
            <assignToReference>var_GroupSum</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Free_Enrollments.hed__Credits_Earned__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txt_UsedEnrollmentIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>;</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txt_UsedEnrollmentIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Free_Enrollments.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Free_Enrollments</targetReference>
        </connector>
    </assignments>

    <assignments>
        <name>Apply_Final_Cap</name>
        <label>Apply Cap</label>
        <locationX>400</locationX>
        <locationY>2300</locationY>
        <assignmentItems>
            <assignToReference>var_TotalCredits</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>form_CappedGroupTotal</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Main_Groups</targetReference>
        </connector>
    </assignments>

    <decisions>
        <name>Decision_Is_Parent</name>
        <label>Is Parent?</label>
        <locationX>400</locationX>
        <locationY>500</locationY>
        <defaultConnector>
            <targetReference>Loop_Scan_Parents</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Parent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>val_Temp_ParentID</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_To_Parent_Collection</targetReference>
            </connector>
            <label>Yes Parent</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_Is_Child</name>
        <label>Is Child of Current?</label>
        <locationX>600</locationX>
        <locationY>1000</locationY>
        <defaultConnector>
            <targetReference>Loop_Scan_Children</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Child</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>val_Temp_ParentID</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_Main_Groups.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_To_Children</targetReference>
            </connector>
            <label>Yes Child</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_Strategy</name>
        <label>Requirement Type</label>
        <locationX>400</locationX>
        <locationY>1200</locationY>
        <defaultConnector>
            <targetReference>Loop_Free_Enrollments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Free Group</defaultConnectorLabel>
        <rules>
            <name>Is_Direct_Course</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Main_Groups.hed__Course__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Extract_Direct_Course_ID</targetReference>
            </connector>
            <label>Direct Course</label>
        </rules>
        <rules>
            <name>Specific_List_Group</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>bool_HasChildren</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Children_Reqs</targetReference>
            </connector>
            <label>Specific List Group</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_Match_Direct</name>
        <label>Match Direct?</label>
        <locationX>500</locationX>
        <locationY>1450</locationY>
        <defaultConnector>
            <targetReference>Loop_Direct_Enrollments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Match_Direct</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>val_Temp_EnrCourseID</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>val_Temp_TargetCourseID</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>formula_IsNotUsed_Direct</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Used_Direct</targetReference>
            </connector>
            <label>Yes Match</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_Match_Spec</name>
        <label>Match Child?</label>
        <locationX>1000</locationX>
        <locationY>1650</locationY>
        <defaultConnector>
            <targetReference>Loop_Spec_Enrollments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Match_Spec</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>val_Temp_EnrCourseID</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>val_Temp_TargetCourseID</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>formula_IsNotUsed_Specific</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Used_Spec</targetReference>
            </connector>
            <label>Yes Match</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_Match_Free</name>
        <label>Available?</label>
        <locationX>800</locationX>
        <locationY>2000</locationY>
        <defaultConnector>
            <targetReference>Loop_Free_Enrollments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Available</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>formula_IsNotUsed_Free</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Used_Free</targetReference>
            </connector>
            <label>Yes Available</label>
        </rules>
    </decisions>

    <formulas>
        <name>form_CappedGroupTotal</name>
        <dataType>Number</dataType>
        <scale>2</scale>
        <expression>IF({!Loop_Main_Groups.hed__Credits__c} > 0, MIN({!var_GroupSum}, {!Loop_Main_Groups.hed__Credits__c}), {!var_GroupSum})</expression>
    </formulas>
    <formulas>
        <name>formula_IsNotUsed_Direct</name>
        <dataType>Boolean</dataType>
        <expression>NOT(CONTAINS({!txt_UsedEnrollmentIDs}, {!Loop_Direct_Enrollments.Id}))</expression>
    </formulas>
    <formulas>
        <name>formula_IsNotUsed_Specific</name>
        <dataType>Boolean</dataType>
        <expression>NOT(CONTAINS({!txt_UsedEnrollmentIDs}, {!Loop_Spec_Enrollments.Id}))</expression>
    </formulas>
    <formulas>
        <name>formula_IsNotUsed_Free</name>
        <dataType>Boolean</dataType>
        <expression>NOT(CONTAINS({!txt_UsedEnrollmentIDs}, {!Loop_Free_Enrollments.Id}))</expression>
    </formulas>

    <loops>
        <name>Loop_Scan_Parents</name>
        <label>Scan for Parents</label>
        <locationX>176</locationX>
        <locationY>400</locationY>
        <collectionReference>Get_All_Plan_Requirements</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Extract_Parent_Check_Var</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Loop_Main_Groups</targetReference>
        </noMoreValuesConnector>
    </loops>

    <loops>
        <name>Loop_Main_Groups</name>
