        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Reset_Group_Vars</targetReference>
        </nextValueConnector>
    </loops>

    <loops>
        <name>Loop_Scan_Children</name>
        <label>Scan Children</label>
        <locationX>400</locationX>
        <locationY>900</locationY>
        <collectionReference>Get_All_Plan_Requirements</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Extract_Child_Check_Var</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Decision_Strategy</targetReference>
        </noMoreValuesConnector>
    </loops>

    <loops>
        <name>Loop_Direct_Enrollments</name>
        <label>Check Direct Match</label>
        <locationX>300</locationX>
        <locationY>1350</locationY>
        <collectionReference>Get_Student_Enrollments</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Extract_Enr_Course_Direct</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Apply_Final_Cap</targetReference>
        </noMoreValuesConnector>
    </loops>

    <loops>
        <name>Loop_Children_Reqs</name>
        <label>Loop Children</label>
        <locationX>600</locationX>
        <locationY>1300</locationY>
        <collectionReference>col_Current_Children</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Extract_Child_Target_Course</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Apply_Final_Cap</targetReference>
        </noMoreValuesConnector>
    </loops>

    <loops>
        <name>Loop_Spec_Enrollments</name>
        <label>Check Match Spec</label>
        <locationX>800</locationX>
        <locationY>1550</locationY>
        <collectionReference>Get_Student_Enrollments</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Extract_Enr_Course_Spec</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Loop_Children_Reqs</targetReference>
        </noMoreValuesConnector>
    </loops>

    <loops>
        <name>Loop_Free_Enrollments</name>
        <label>Loop Free Enr</label>
        <locationX>600</locationX>
        <locationY>1900</locationY>
        <collectionReference>Get_Student_Enrollments</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Decision_Match_Free</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Apply_Final_Cap</targetReference>
        </noMoreValuesConnector>
    </loops>

    <recordLookups>
        <name>Get_All_Plan_Requirements</name>
        <label>Get All Plan Requirements</label>
        <locationX>176</locationX>
        <locationY>158</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Student_Enrollments</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>hed__Program_Plan__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_PlanID</elementReference>
            </value>
        </filters>
        <object>hed__Plan_Requirement__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
        <sortField>hed__Sequence__c</sortField>
        <sortOrder>Asc</sortOrder>
    </recordLookups>

    <recordLookups>
        <name>Get_Student_Enrollments</name>
        <label>Get Student Enrollments</label>
        <locationX>176</locationX>
        <locationY>278</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Scan_Parents</targetReference>
        </connector>
        <filterLogic>1 AND (2 OR 3 OR 4)</filterLogic>
        <filters>
            <field>hed__Program_Enrollment__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_PEID</elementReference>
            </value>
        </filters>
        <filters>
             <field>Notations__c</field>
             <operator>EqualTo</operator>
             <value>
                 <stringValue>R</stringValue>
             </value>
        </filters>
        <filters>
             <field>Notations__c</field>
             <operator>EqualTo</operator>
             <value>
                 <stringValue>EQV</stringValue>
             </value>
        </filters>
        <filters>
             <field>Notations__c</field>
             <operator>EqualTo</operator>
             <value>
                 <stringValue>Transfer</stringValue>
             </value>
        </filters>
        <object>hed__Course_Enrollment__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>

    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Get_All_Plan_Requirements</targetReference>
        </connector>
    </start>

    <variables>
        <name>var_PlanID</name>
        <dataType>String</dataType>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>var_PEID</name>
        <dataType>String</dataType>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>var_TotalCredits</name>
        <dataType>Number</dataType>
        <scale>2</scale>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
        <value>
            <numberValue>0.0</numberValue>
        </value>
    </variables>

    <variables>
        <name>val_Temp_ParentID</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
    </variables>
    <variables>
        <name>val_Temp_TargetCourseID</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
    </variables>
    <variables>
        <name>val_Temp_EnrCourseID</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
    </variables>

    <variables>
        <name>col_Parents</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <objectType>hed__Plan_Requirement__c</objectType>
    </variables>
    <variables>
        <name>col_Current_Children</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <objectType>hed__Plan_Requirement__c</objectType>
    </variables>
    <variables>
        <name>col_Empty_Template</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <objectType>hed__Plan_Requirement__c</objectType>
    </variables>

    <variables>
        <name>txt_UsedEnrollmentIDs</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <value>
            <stringValue>;</stringValue>
        </value>
    </variables>
    <variables>
        <name>var_GroupSum</name>
        <dataType>Number</dataType>
        <scale>2</scale>
    </variables>
    <variables>
        <name>bool_HasChildren</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>

</Flow>