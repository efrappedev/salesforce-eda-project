            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txt_UsedEnrollmentIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>;</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>txt_UsedEnrollmentIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Direct_Enrollments.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Apply_Final_Cap</targetReference>
        </connector>
    </assignments>

    <assignments>
        <name>Assign_Used_Spec</name>
