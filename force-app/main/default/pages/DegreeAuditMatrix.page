<apex:page controller="DegreeAuditMatrixController" sidebar="false" showHeader="false" docType="html-5.0">
  <!-- CSS global -->
  <apex:stylesheet value="{!URLFOR($Resource.DegreeAuditCSS)}"/>

  <!-- Librerías para PDF en el navegador -->
  <apex:includeScript value="{!URLFOR($Resource.html2canvas_min)}"/>
  <apex:includeScript value="{!URLFOR($Resource.jsPDF, 'jspdf.umd.min.js')}"/>

  <!-- actionFunction para cerrar modal en servidor -->
  <apex:form id="modalForm">
  <apex:actionFunction name="closeDetail" action="{!closeStudentDetail}" rerender="studentModal"/>
  <apex:actionFunction name="reRun" action="{!runAudit}" rerender="tblPanel,csvPanel,filterPanel,notePanel" status="stGlobal" oncomplete="applyStickyOffsets(); initTableSorters(); initBtnRipple();"/>
    </apex:form>
    
  <div class="da-container">
    <div class="da-title">Degree Audit (EDA) — Matrice par Plan de Programme</div>

    <!-- Toolbar -->
    <div class="da-toolbar">
    <div class="group">
    <apex:form styleClass="inline-form">
      <span class="muted">Statut du plan</span>
      <apex:selectList id="planStatus" value="{!planStatusFilter}" size="1" styleClass="da-select">
        <apex:selectOptions value="{!planStatusOptions}"/>
      </apex:selectList>

      <span class="muted">Inscriptions (PE)</span>
      <apex:selectList id="peStatus" value="{!peStatusFilter}" size="1" styleClass="da-select" style="max-width:280px;">
        <apex:selectOptions value="{!peStatusOptions}"/>
      </apex:selectList>

      <apex:commandButton value="Appliquer filtres" styleClass="da-btn-secondary"
                          action="{!updatePlanOptions}"
                          rerender="pp"
                          status="stGlobal"
                          oncomplete="if(typeof reRun==='function'){ reRun(); }"/>

      <span class="ico-help" onclick="showHelpFilters(event)" title="Aide">i</span>
    </apex:form>
      </div>
      <div class="group">
        <apex:form styleClass="inline-form">
          <apex:outputLabel value="Programme" for="pp" styleClass="muted"/>
          <apex:selectList id="pp" value="{!selectedProgramPlanId}" size="1" styleClass="da-select" disabled="{!isPortalView}">
            <apex:selectOptions value="{!programPlanOptions}"/>
          </apex:selectList>

          <apex:commandButton value="Générer matrice" styleClass="da-btn"
                              action="{!runAudit}"
                              rerender="tblPanel,csvPanel,filterPanel,notePanel"
                              status="stGlobal"
                              oncomplete="applyStickyOffsets(); initTableSorters(); initBtnRipple(); initStickyStabilizer();"
                              rendered="{!NOT(isPortalView)}"/>

          <!-- === Filtro de curso === -->
                      <apex:outputPanel id="filterPanel"
                              layout="inline"
                              styleClass="{!IF(hasData,'','is-disabled')}"
                              style="margin-left:10px;">
              <span class="muted">Cours</span>
            
              <apex:selectList id="reqFilter"
                               value="{!selectedRequirementId}"
                               size="1"
                               styleClass="da-select"
                               disabled="{!NOT(hasData)}">
                <apex:selectOptions value="{!requirementPicklist}"/>
              </apex:selectList>
            
              <apex:commandButton value="Filtrer"
                                  styleClass="da-btn-secondary"
                                  rerender="tblPanel"
                                  disabled="{!NOT(hasData)}"
                                  status="stGlobal"
                                  oncomplete="applyStickyOffsets(); initTableSorters(); initBtnRipple(); initStickyStabilizer();"/>
            </apex:outputPanel>
        </apex:form>
      </div>

      <div class="group">
        <a href="javascript:void(0)" class="da-export" onclick="exportCsvSmart()">Exporter CSV</a>
      </div>
    </div>

    <!-- Nota de tooltips -->
    <apex:outputPanel rendered="{!NOT(isPortalView)}" layout="block">
      <div class="note-fr mt-16" rendered="{!hasData}">
        Astuce : survolez ✔/✖ pour voir le statut, la note et la période. /// Cliquez sur l’en-tête d’une colonne pour trier (▲/▼).
      </div>
      <div class="note-fr mt-16" rendered="{!NOT(hasData)}">
        Sélectionnez un programme puis cliquez sur “Générer matrice”.
      </div>
    </apex:outputPanel>

    <!-- Matriz -->
    <apex:outputPanel id="tblPanel" layout="block">
      <apex:outputPanel id="notePanel" rendered="{!NOT(isPortalView)}" layout="block">
        <apex:outputPanel rendered="{!OR(hasData, NOT(ISBLANK(selectedProgramPlanId)))}" layout="block">
          <div class="da-table-wrap" id="daTableWrap" style="max-height: calc(100vh - 240px); overflow:auto;">
            <table class="da-table">
              <thead>
                <tr>
                  <th class="da-col-idx sortable" data-type="num">#</th>
                  <th class="da-col-student sortable" data-type="text">ÉTUDIANT</th>
                  <th class="da-col-email sortable" data-type="text">EMAIL</th>
                  <th class="sortable" data-type="text">ID CONTACT</th>

                  <th class="sortable" data-type="num">MANQUANTS</th>
                  <th class="sortable" data-type="num">% AVANCEMENT</th>
                  <th class="sortable" data-type="date">DERNIER COURS</th>

                  <th class="sortable" data-type="bool7">
                    7+ ANS
                    <span class="ico-help" onclick="showHelp7ans(event)">i</span>
                  </th>

                  <!-- Repetición de cursos AL FINAL (sortable bool) -->
                  <apex:repeat value="{!requirements}" var="r">
                    <apex:outputPanel layout="none" rendered="{!OR(ISBLANK(selectedRequirementId), r.Id = selectedRequirementId)}">
                      <th class="sortable" data-type="bool">
                        {!r.Name}
                        <br/>
                        <span class="muted">(
                          <apex:outputText value="{!reqOkCountsSafe[r.Id]}"/>
                          /{!studentsCount}
                        )</span>
                      </th>
                    </apex:outputPanel>
                  </apex:repeat>
                  
                  <!-- === BLOQUES OPTATIVOS AL FINAL (ocultos si hay filtro de curso) === -->
                <apex:outputPanel layout="none" rendered="{!AND(ISBLANK(selectedRequirementId), hasOptBlocks)}">
                      <apex:repeat value="{!optBlocks}" var="block">
                        <th class="sortable" data-type="num" data-opt="1">
                          {!block.name}
                          <br/>
                          <span class="muted">(
                              <apex:outputText value="{0, number, 0.0}">
                                <apex:param value="{!block.requiredCredits}"/>
                              </apex:outputText>
                              u.)
                            </span>
                        </th>
                      </apex:repeat>
                    </apex:outputPanel>                
                </tr>
              </thead>

              <tbody>
                <apex:variable var="rowNum" value="{!0}"/>
                <apex:repeat value="{!rows}" var="row">
                  <apex:variable var="rowNum" value="{!rowNum + 1}"/>
                  <tr>
                    <td class="da-col-idx">{!rowNum}</td>

                    <td class="da-col-student da-stu">
                  <apex:form styleClass="inline-form">
                    <div class="student-name">
                          <apex:commandLink value="{!row.DisplayName}"
                                            action="{!openStudentDetailAction}"
                                            rerender="studentModal"
                                            status="stGlobal"
                                            oncomplete="openModal()"
                                            style="display:block; text-align:left;">
                            <apex:param name="contactId" value="{!row.ContactId}"/>
                          </apex:commandLink>
                        </div>
                      </apex:form>
                    </td>

                    <td class="da-col-email">
                      <span class="student-email">{!row.Email}</span>
                    </td>

                    <!-- ID CONTACT como hyperlink a la ficha del Contact -->
                        <td>
                          <apex:outputPanel rendered="{!NOT(ISBLANK(row.ContactExternalId))}" layout="none">
                            <a href="javascript:;" 
                               onclick="openContactRecord('{!row.ContactId}')"
                               title="Ouvrir fiche Contact"
                               style="color:#1b66e3; text-decoration:underline;">
                              {!row.ContactExternalId}
                            </a>
                          </apex:outputPanel>
                          <apex:outputPanel rendered="{!ISBLANK(row.ContactExternalId)}" layout="none">—</apex:outputPanel>
                        </td>

                    <td>{!row.MissingCount}</td>
                    <td>{!row.ProgressPercentText}</td>
                    <td>{!row.LastCourseDateText}</td>

                    <!-- 7+ ans -->
                    <td>
                      <apex:outputText rendered="{!row.OlderThan7Years}"
                                       value="&#x26D4;" styleClass="ico miss" escape="false"
                                       title="Dernier cours: 7 ans ou plus"/>
                      <apex:outputText rendered="{!NOT(row.OlderThan7Years)}"
                                       value="&#x2705;" styleClass="ico ok" escape="false"
                                       title="Dernier cours: moins de 7 ans"/>
                    </td>

                

                    <!-- ✔/✖ por requirement con tooltip (filtrado) — AL FINAL -->
                    <apex:repeat value="{!requirements}" var="r">
                      <apex:outputPanel layout="none" rendered="{!OR(ISBLANK(selectedRequirementId), r.Id = selectedRequirementId)}">
                        <td>
                          <apex:outputText rendered="{!row.mapReqToOk[r.Id]}"
                                             value="&#10003;" styleClass="ico ok"
                                             title="{!row.mapReqToTip[r.Id]}" escape="false"/>
                            <apex:outputText rendered="{!NOT(row.mapReqToOk[r.Id])}"
                                             value="&#10005;" styleClass="ico miss"
                                             title="{!row.mapReqToTip[r.Id]}" escape="false"/>
                        </td>
                      </apex:outputPanel>
                    </apex:repeat>
                    
                    <!-- === Celdas por alumno de bloques optativos (DENTRO del <tr>) === -->
                    <apex:outputPanel layout="none" rendered="{!AND(ISBLANK(selectedRequirementId), hasOptBlocks)}">
                      <apex:repeat value="{!optBlocks}" var="block">
                        <td data-opt="1"
                            title="{!row.mapOptTipByPrId[block.prId]} — {!row.mapOptEarnByPrId[block.prId]} / {!IF(AND(NOT(ISNULL(block.requiredCredits)), block.requiredCredits>0), block.requiredCredits, '—')}">
                        
                          <!-- Créditos GANADOS: SIN tope, 1 decimal -->
                          <apex:outputText value="{0, number, 0.0}">
                            <apex:param value="{!row.mapOptEarnByPrId[block.prId]}"/>
                          </apex:outputText>
                        
                          <apex:outputText value=" / "/>
                        
                          <!-- Créditos REQUERIDOS: 1 decimal si aplica -->
                          <apex:outputText rendered="{!AND(NOT(ISNULL(block.requiredCredits)), block.requiredCredits > 0)}"
                                           value="{0, number, 0.0}">
                            <apex:param value="{!block.requiredCredits}"/>
                          </apex:outputText>
                          <apex:outputText rendered="{!OR(ISNULL(block.requiredCredits), block.requiredCredits = 0)}" value="—"/>
                        </td>
                      </apex:repeat>
                    </apex:outputPanel>
                  </tr>
                </apex:repeat>
                
                <!-- Empty states (colspan ajustado al filtro) -->
                <apex:outputPanel rendered="{!AND(NOT(hasData), NOT(ISBLANK(selectedProgramPlanId)))}">
                  <tr>
                    <td colspan="{!4 + (IF(ISBLANK(selectedRequirementId), requirementsCount, 1)) + 4 + IF(AND(hasOptBlocks, ISBLANK(selectedRequirementId)), optBlocks.size, 0)}" class="da-empty">
                      Aucun résultat. Vérifiez que le plan sélectionné possède des exigences (cours) et des inscriptions d’étudiants.
                    </td>
                  </tr>
                </apex:outputPanel>

                <apex:outputPanel rendered="{!ISBLANK(selectedProgramPlanId)}">
                  <tr>
                    <td colspan="{!4 + (IF(ISBLANK(selectedRequirementId), requirementsCount, 1)) + 4 + IF(AND(hasOptBlocks, ISBLANK(selectedRequirementId)), optBlocks.size, 0)}" class="da-empty">
                      Sélectionnez d’abord un programme.
                    </td>
                  </tr>
                </apex:outputPanel>
              </tbody>
            </table>
          </div>
        </apex:outputPanel>

        <!-- Mensaje para portal (solo detalle) -->
        <apex:outputPanel rendered="{!isPortalView}" layout="block">
          <div class="note-fr">Vue portail: la matrice n’est pas affichée. Ouvrez le détail de l’étudiant.</div>
        </apex:outputPanel>
      </apex:outputPanel>
    </apex:outputPanel>

    <!-- CSV oculto -->
    <apex:outputPanel id="csvPanel" layout="block">
      <pre id="csvData" class="csv-hidden">{!csvContent}</pre>
    </apex:outputPanel>

    <!-- ===== Modal: Détail Étudiant ===== -->
    <apex:outputPanel id="studentModal" layout="block">
      <div id="modalOverlay" class="modal-overlay" style="display:{!IF(showDetail,'block','none')}"></div>
      <div id="modalPanel" class="modal-panel" style="display:{!IF(showDetail,'block','none')}">
        <div class="modal-header">
          <div class="modal-title">Détail de l’étudiant</div>
          <div class="spacer"></div>
          <button class="modal-close" onclick="closeModal()">×</button>
        </div>

        <div class="modal-body" style="max-height: calc(100vh - 220px); overflow:auto; padding-bottom:0;">
          <apex:outputPanel rendered="{!showDetail}">
            <!-- CAPTURA PDF -->
            <div id="studentDetailCapture">
              <div class="detail-grid">
                <div><span class="muted">Nom:</span> <strong>{!studentDetail.DisplayName}</strong></div>
                <div><span class="muted">Plan:</span> <strong>{!studentDetail.PlanName}</strong></div>
                <div><span class="muted">Avancement:</span> <strong>{!studentDetail.ProgressPercentText}</strong></div>
                <div><span class="muted">Dernier cours:</span> <strong>{!studentDetail.LastCourseDateText}</strong></div>
                <div>
                  <span class="muted">7+ ans:</span>
                  <strong>
                    <apex:outputText rendered="{!studentDetail.OlderThan7Years}" value="&#x26D4;" styleClass="ico miss" escape="false"/>
                    <apex:outputText rendered="{!NOT(studentDetail.OlderThan7Years)}" value="&#x2705;" styleClass="ico ok" escape="false"/>
                  </strong>
                </div>
                <div><span class="muted">Manquants:</span> <strong>{!studentDetail.MissingCount}</strong></div>
                <div><span class="muted">Email:</span> <strong>{!studentDetail.Email}</strong></div>
                <!-- ID Contact en modal -->
                <div><span class="muted">ID Contact:</span> <strong id="contactExternalId">{!studentDetail.ContactExternalId}</strong></div>
              </div>

              <div class="detail-columns">
              <div class="col-main">
                <div class="detail-table-wrap">
                  <table class="detail-table" id="detailTable">
                    <thead>
                      <tr>
                        <th style="width:80px;text-align:center;">Statut</th>
                        <th>Nom du cours</th>
                      </tr>
                    </thead>
                    <tbody id="detailTbody">
                      <apex:repeat value="{!studentDetail.Courses}" var="c">
                        <tr>
                          <td style="text-align:center;">
                            <apex:outputText rendered="{!c.IsOk}" value="&#10003;" styleClass="ico ok"
                                             title="{!c.Tooltip}" escape="false"/>
                            <apex:outputText rendered="{!NOT(c.IsOk)}" value="&#10005;" styleClass="ico miss"
                                             title="{!c.Tooltip}" escape="false"/>
                          </td>
                          <td>{!c.CourseName}</td>
                        </tr>
                      </apex:repeat>
                    </tbody>
                  </table>
                </div>
              </div>
            </div> <!-- /detail-columns -->
            
            </div> <!-- /#studentDetailCapture -->
            </apex:outputPanel> <!-- /rendered="{!showDetail}" -->
            </div> <!-- /.modal-body -->

        <!-- CSV oculto del modal -->
        <pre id="detailCsv" class="csv-hidden">{!detailCsvContent}</pre>

        <!-- Barra de acciones -->
        <div class="modal-actions">
          <a href="javascript:void(0)" class="da-btn-secondary" onclick="exportCsvSmart()">Exporter CSV (Étudiant)</a>
          <a href="javascript:void(0)" class="da-btn" onclick="exportPdfSmart()">Exporter PDF</a>

          <!-- Solo mostrar a usuarios internes -->
          <apex:outputLink value="/lightning/r/Contact/{!studentDetail.ContactId}/view"
                           styleClass="da-btn-secondary"
                           target="_blank" rel="noopener"
                           rendered="{!NOT(isPortalView)}">
            Voir fiche Contact
          </apex:outputLink>

          <a href="javascript:void(0)" class="da-btn" onclick="closeModal()">Fermer</a>
        </div>
      </div>
    </apex:outputPanel>
  </div>

  <!-- ==================== CSV & HELPERS ==================== -->
  <script>
          // Devuelve "Nombre del bloque (N u.)" sin arrastres como "(3.000 u.) (3.000 u.)"
        function buildOptTitleFromTH(th){
          if (!th) return '';
        
          // 1) base: primer nodo de texto del TH (sin muteds ni otras partes)
          var base = '';
          if (th.childNodes && th.childNodes.length && th.childNodes[0].nodeType === 3){
            base = (th.childNodes[0].nodeValue || '').trim();
          } else {
            base = ((th.textContent || '').split('\n')[0] || '').trim();
          }
          // quita cualquier "(...)" ya pegado al final del base
          base = base.replace(/\s*\(.*?\)\s*$/, '');
        
          // 2) créditos desde el <span class="muted">…</span>
          var muted = th.querySelector('.muted');
          var creditsText = muted ? (muted.textContent || '') : '';
          // extrae el primer número (soporta "3.000", "12", "12,0", etc.)
          var m = creditsText.match(/[\d\.]+/);
          var creditsNum = m ? m[0].replace(/\./g,'') : '';   // "3.000" -> "3000"
          if (creditsNum){
            // si venía "3000" pero conceptualmente son "3 u.", ajusta según tu caso.
            // Aquí lo tratamos como entero simple (3, 12, etc.)
            try { creditsNum = String(parseInt(creditsNum,10)); } catch(_e){}
            return base + ' (' + creditsNum + ' u.)';
          }
          return base;
        }
        
        // Limpia prefijos de término/código y banderas como (R), (EQV), etc.
        function cleanCourseName(s){
          if(!s) return '';
          s = String(s).replace(/&nbsp;/gi, ' ');
        
          // Quita viñetas/checks/dashes al inicio
          s = s.replace(/^[\s\u2713\u2714\u2705\u2022•\-]+/, '');
        
          // Quita banderas en cualquier parte
          s = s.replace(/\s*\((?:R|EQV|TR\/?EX?|EXV?)\)\s*/gi, ' ');
        
          // Quita prefijos acumulados: A/H/P 20xx, rangos 019-20/2020-21, año suelto 2021, etc.
          const rePrefix = /^\s*(?:[AHP]\s*20\d{2}|[AHP]\d{4}|\d{4}\s*-\s*\d{2}|\d{3}\s*-\s*\d{2}|\d{2}\s*-\s*\d{2}|\d{4})\s*/i;
          while (rePrefix.test(s)) s = s.replace(rePrefix, '');
        
          return s.replace(/\s{2,}/g, ' ').trim();
        }
        
        // Normaliza y extrae la lista de cursos desde el title del <td data-opt="1">
        // Funciona tanto si vienen con saltos de línea como si todo está en una sola línea.
        function parseOptTooltip(ttl){
          if (!ttl) return [];
        
            if (!ttl) return [];

          // Normalizar entidades y saltos (si existieran)
          ttl = ttl
            .replace(/&nbsp;/gi, ' ')
            .replace(/&lt;br\s*\/?&gt;|<br\s*\/?>/gi, '\n')
            .replace(/&#10;|&NewLine;|\\n/g, '\n')
            .replace(/\r\n/g, '\n')
            .replace(/\r/g, '\n')
            .trim();
        
          // Quitar el total a la derecha “— 12.000 / 12.000”
          var left = ttl.split(' — ')[0] || ttl;
        
          // 1) Primer intento: separar por saltos/viñetas/; | ,
          var items = left.split(/[\n\u2022•;|,]+/g)
            .map(function(s){ return (s||'').trim(); })
            .filter(Boolean);
        
          function onlyName(s){
            var ix = s.indexOf(' · ');
            var raw = (ix >= 0 ? s.substring(0, ix) : s).trim();
            return cleanCourseName(raw);
          }
          if (items.length > 1){
            var seen1 = Object.create(null), out1 = [];
            items.forEach(function(s){
              var name = onlyName(s);
              if (name && !seen1[name]){ seen1[name] = 1; out1.push(name); }
            });
            if (out1.length) return out1;
          }
        
          // 2) Fallback robusto para una sola línea:
          // Busca patrones repetidos: "<curso> · <n>u · <algo...>" y extrae <curso>
          var re = /(.+?)\s*·\s*[\d.,]+u\s*·\s*(?:[^—]+?)(?=(?:\s*.+?\s*·\s*[\d.,]+u\s*·)|\s*$|\s*—)/g;
          var m, seen = Object.create(null), out = [];
          while ((m = re.exec(left)) !== null){
            var name = cleanCourseName((m[1] || '').trim());
            if (name && !seen[name]){ seen[name] = 1; out.push(name); }
          }
          if (out.length) return out;
        
          // 3) Último recurso: si no pudo reconocer el patrón, sacar el primer “nombre · …”
          var ix = left.indexOf(' · ');
          return (ix > 0) ? [ cleanCourseName(left.substring(0, ix).trim()) ] : [];
        }

        
        // NUEVO: deja el title de los bloques optativos solo con nombres (y conserva el " — X / Y")
        function sanitizeOptTitles(){
          try{
            var tds = document.querySelectorAll('.da-table td[data-opt="1"]');
            tds.forEach(function(td){
              var raw = td.getAttribute('title') || '';
              td.dataset.rawtitle = raw;                      
            
              var names = parseOptTooltip(raw);
              var right = '';
              var ix = raw.indexOf(' — ');
              if (ix >= 0) right = raw.substring(ix);
              var clean = (names && names.length ? names.join('\n') : '');
              td.setAttribute('title', clean + right);
            });
            } catch(e){ console.warn('sanitizeOptTitles error', e); }
            }


        
        // Mapa índiceColumna -> título limpio del bloque (para usarlo como cabecera del popover)
        function mapOptBlockTitles(){
          var map = {};
          var thead = document.querySelector('.da-table thead');
          if (!thead) return map;
          var ths = thead.querySelectorAll('th[data-opt="1"]');
          ths.forEach(function(th){
            var idx = th.cellIndex;
            var title = (function(th){
              if (!th) return '';
              var base = (th.childNodes && th.childNodes[0] && th.childNodes[0].nodeType === 3)
                ? (th.childNodes[0].nodeValue || '').trim()
                : ((th.textContent || '').split('\n')[0] || '').trim();
              base = base.replace(/\s*\(.*?\)\s*$/, '');
              var muted = th.querySelector('.muted');
              var credits = muted ? (muted.textContent || '').trim() : '';
              return credits ? (base + ' ' + credits) : base;
            })(th);
            map[idx] = title;
          });
          return map;
        }
        
        // Muestra el popover con la lista de cursos en la posición del click
            function showOptCoursesPopover(ev, blockTitle, courses){
              var pop = document.getElementById('optPopover');
              if (!pop) return;
            
              // Cierra el de ayuda si quedó abierto
              try{
                var help = document.getElementById('helpPopover');
                if (help) help.style.display = 'none';
              }catch(_e){}
            
              // Contenido
              var html = '<div style="font-weight:600;margin-bottom:6px;">' +
                           (blockTitle || 'Cours au choix') +
                         '</div>';
              if (courses && courses.length){
                html += '<ul style="margin:0;padding-left:16px;">' +
                  courses.map(function(c){ return '<li>'+c+'</li>'; }).join('') +
                  '</ul>';
              } else {
                html += '<div class="muted">Aucun cours listé.</div>';
              }
              pop.innerHTML = html;
              pop.setAttribute('role','dialog');
              pop.setAttribute('aria-hidden','false');
            
              // Mostrar para poder medir
              pop.style.display = 'block';
              pop.style.left = '0px';
              pop.style.top  = '0px';
            
              // Medidas/viewport
              var vw = Math.max(document.documentElement.clientWidth,  window.innerWidth  || 0);
              var vh = Math.max(document.documentElement.clientHeight, window.innerHeight || 0);
              var pw = pop.offsetWidth, ph = pop.offsetHeight;
            
              // Posición preferida: debajo del cursor
              var margin = 10;
              var x = ev.clientX + 8;
              var y = ev.clientY + margin;
              var showBelow = true;
            
              // Si no cabe abajo, muévelo arriba y marca .above
              if (y + ph + 8 > vh){
                y = ev.clientY - ph - margin;
                showBelow = false;
              }
              // Ajustes laterales
              if (x + pw + 8 > vw) x = Math.max(8, vw - pw - 8);
              if (x < 8) x = 8;
            
              // Aplica clases iguales que el popover de 7+ años
              pop.classList.remove('below','above');
              pop.classList.add(showBelow ? 'below' : 'above');
            
              // Fija posición
              pop.style.left = x + 'px';
              pop.style.top  = y + 'px';
            
              // Cerrar al click fuera / Escape / scroll
              function hide(ev2){
                if (pop.contains(ev2.target)) return;
                pop.style.display = 'none';
                pop.setAttribute('aria-hidden','true');
                document.removeEventListener('click', hide, true);
                window.removeEventListener('scroll', hide, true);
                document.removeEventListener('keydown', onKey, true);
              }
              function onKey(e){ if (e.key === 'Escape') hide(e); }
            
              setTimeout(function(){
                document.addEventListener('click', hide, true);
                window.addEventListener('scroll', hide, true);
                document.addEventListener('keydown', onKey, true);
              }, 0);
            }
       
        // Escanea la tabla y conecta el click a cada <td data-opt="1">
        function initOptBlockClickReveal(){
          try{
            var table = document.querySelector('.da-table');
            if (!table) return;
        
            var titleByIdx = mapOptBlockTitles();
        
            // Delegación por rendimiento: click en tbody
            var tbody = table.tBodies && table.tBodies[0];
            if (!tbody) return;
        
            // Evita duplicar listeners
            if (tbody.dataset.optRevealAttached === '1') return;
        
            tbody.addEventListener('click', function(ev){
              var td = ev.target.closest('td[data-opt="1"]');
              if (!td) return;
        
              // Título del bloque por índice de columna
              var colIdx = td.cellIndex;
              var blockTitle = titleByIdx[colIdx] || '';
        
              // Lista de cursos desde el title ORIGINAL (antes de sanear)
              var raw = td.dataset.rawtitle || td.getAttribute('title') || '';
              var courses = parseOptTooltip(raw);
              showOptCoursesPopover(ev, blockTitle, courses);
        
              showOptCoursesPopover(ev, blockTitle, courses);
            }, false);
        
            tbody.dataset.optRevealAttached = '1';
          }catch(e){ console.warn('initOptBlockClickReveal error', e); }
        }

  
        function exportCsvSmart(){
          try{
        // 1) ¿Modal abierto?
        var modalOpen = (function(){
          var p = document.getElementById('modalPanel');
          return p && p.style.display === 'block';
        })();
    
        // Helpers CSV
        // --- Delimitador dinámico para CSV (Numbers en Mac FR -> ';', resto -> ',') ---
        var CSV_DELIM = (function getCsvDelimiter(){
          try{
            var lang = (navigator.language || '').toLowerCase();
            var isMac = /mac/i.test(navigator.platform || '');
            var commaDecimal = (1.1).toLocaleString().indexOf(',') > -1;
            if (isMac && (lang.startsWith('fr') || commaDecimal)) return ';';
          }catch(e){}
          return ',';
        })();
    
        // Pista para hojas de cálculo (solo cuando usamos ';')
        function csvSepHint(){
          // No añadir pista en Mac/Numbers ni cuando usamos ';'
          try{
            var ua = navigator.userAgent || '';
            var isMac = /Mac/i.test(navigator.platform || '') || /Macintosh|Mac OS X/.test(ua);
            if (isMac || CSV_DELIM === ';') return '';
          }catch(e){}
          // Mantener pista solo para Excel (coma)
          return 'sep=,\r\n';
        }
    
        function splitCSVLine(s){
          var out=[], cur='', q=false;
          for (var i=0;i<s.length;i++){
            var ch=s[i];
            if (ch === '"'){
              if (q && s[i+1] === '"'){ cur+='"'; i++; }
              else { q=!q; }
            } else if (ch === ',' && !q){
              out.push(cur); cur='';
            } else { cur+=ch; }
          }
          out.push(cur);
          return out;
        }
        function joinCSVLine(arr){
          return arr.map(function(v){
            v = v==null ? '' : String(v);
            return '"' + v.replace(/"/g,'""') + '"';
          }).join(CSV_DELIM);
        }
        function download(name, text){
          // 1) BOM para Excel + 2) forzar CRLF
          var BOM = '\uFEFF';
          var normalized = (text || '')
            .replace(/\r\n/g, '\n')
            .replace(/\r/g, '\n')
            .replace(/\n/g, '\r\n');
    
          var dataUrl = 'data:text/csv;charset=utf-8,' + encodeURIComponent(BOM + normalized);
    
          var a = document.createElement('a');
          a.style.display = 'none';
          a.href = dataUrl;
          a.download = name;
          document.body.appendChild(a);
          a.click();
          setTimeout(function(){ document.body.removeChild(a); }, 0);
    
          // Safari/iOS fallback (mismo dataUrl con BOM+CRLF)
          var ua = navigator.userAgent || '';
          var isIOS = /iP(ad|hone|od)/.test(ua);
          var isSafari = /^((?!chrome|android).)*safari/i.test(ua);
          if (isSafari || isIOS){
            try{
              var iframe = document.createElement('iframe');
              iframe.style.display = 'none';
              iframe.src = dataUrl;
              document.body.appendChild(iframe);
              setTimeout(function(){ document.body.removeChild(iframe); }, 1500);
            }catch(e){}
          }
        }
    
        // 2) Si modal: exporta CSV de detalle (ID solo en primera fila)
        if (modalOpen){
          var elDet = document.getElementById('detailCsv');
          var det   = elDet ? (elDet.textContent || elDet.innerText || '') : '';
          if (!det || !det.trim()){ alert('Aucun contenu CSV pour l’étudiant.'); return; }
    
          var lines = det.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');
          if (lines.length && !lines[lines.length-1].trim()) lines.pop();
    
          function idxOfCI(arr, names){
            var lower = arr.map(function(h){ return (h||'').toLowerCase(); });
            for (var i=0;i<names.length;i++){
              var k = lower.indexOf((names[i]||'').toLowerCase());
              if (k >= 0) return k;
            }
            return -1;
          }
    
          var header = splitCSVLine(lines[0]);
          var idxFirst = idxOfCI(header, ['Prénom','Prenom']);
          var idxLast  = idxOfCI(header, ['Nom']);
          var idxEt    = idxOfCI(header, ['Étudiant','Etudiant']);
    
          if ((idxFirst < 0 || idxLast < 0) && idxEt >= 0){
            header.splice(idxEt, 1, 'Prénom', 'Nom');
            lines[0] = joinCSVLine(header);
            for (var r=1; r<lines.length; r++){
              if (!lines[r]) continue;
              var cols = splitCSVLine(lines[r]);
              if (cols.length > idxEt){
                var full  = cols[idxEt] || '';
                var parts = full.trim().split(/\s+/);
                var first = '', last = '';
                if (parts.length === 1){ first = parts[0]; }
                else if (parts.length > 1){ last = parts.pop(); first = parts.join(' '); }
                cols.splice(idxEt, 1, first, last);
                lines[r] = joinCSVLine(cols);
              }
            }
            header  = splitCSVLine(lines[0]);
          }
    
          var idxEmail = idxOfCI(header, ['Email','Courriel']);
          var idxIdCol = idxOfCI(header, ['ID Contact','ID_Contact__c','ContactExternalId']);
    
          var idVal = '';
          var idEl  = document.getElementById('contactExternalId');
          if (idEl && idEl.textContent) idVal = idEl.textContent.trim();
    
          if (idxEmail >= 0){
            if (idxIdCol < 0){
              header.splice(idxEmail + 1, 0, 'ID Contact');
              lines[0] = joinCSVLine(header);
              for (var r=1; r<lines.length; r++){
                if (!lines[r]) continue;
                var cols = splitCSVLine(lines[r]);
                cols.splice(idxEmail + 1, 0, (r === 1 ? (idVal || '') : ''));
                lines[r] = joinCSVLine(cols);
              }
            } else {
              for (var r=1; r<lines.length; r++){
                if (!lines[r]) continue;
                var cols = splitCSVLine(lines[r]);
                if (r === 1){
                  if (idVal) cols[idxIdCol] = idVal;
                } else {
                  if (cols.length > idxIdCol) cols[idxIdCol] = '';
                }
                lines[r] = joinCSVLine(cols);
              }
            }
          }
      
      // === APÉNDICE: Bloques optativos del alumno (si están visibles en la matriz) ===
        try{
          // 1) Tomar el nombre mostrado en el modal
          var modalNameEl = document.querySelector('#studentDetailCapture .detail-grid strong');
          var modalName = (modalNameEl && modalNameEl.textContent) ? modalNameEl.textContent.trim() : '';
        
          // 2) Buscar en la tabla la fila del mismo alumno
          //    (usa el texto del link en la columna "ÉTUDIANT")
          var rowsDom = document.querySelectorAll('.da-table tbody tr');
          var rowDom = null;
          for (var i=0;i<rowsDom.length;i++){
            var a = rowsDom[i].querySelector('.student-name a, .da-col-student a');
            var nm = a ? a.textContent.trim() : '';
            if (nm === modalName){ rowDom = rowsDom[i]; break; }
          }
        
          // 3) Si no hay fila o no hay columnas optativas visibles (p.ej. filtraste por curso), no añadimos nada
          var optHeaders = document.querySelectorAll('.da-table thead th[data-opt="1"]');
          if (rowDom && optHeaders && optHeaders.length){
            var optCells = rowDom.querySelectorAll('td[data-opt="1"]');
        
            // separador visual entre la sección de "Statut, Nom du cours" y optativos
            lines.push('');
        
            // Recorre cada bloque optativo (header -> celda correspondiente)
            for (var k=0; k<optHeaders.length && k<optCells.length; k++){
              var th = optHeaders[k];
              var td = optCells[k];
        
              // Título limpio: "Nombre del bloque (N u.)"
                var blockTitle = buildOptTitleFromTH(th);
                lines.push(joinCSVLine(['', blockTitle]));
        
              // 4) Del tooltip de la celda (td.title) extraemos los cursos usados para ese bloque
              //    El mapa que ya imprimes trae una lista (una por línea) en la primera parte del title.
              //    Ej: "Curso 1 · 3u\nCurso 2 · 3u — 6 / 12"
              var ttl = td.getAttribute('title') || '';
              // Tomar solo la parte izquierda antes del " — " (cursos por línea)
              var left = ttl.split(' — ')[0] || '';
              var linesTip = left.split('\n');
        
              linesTip.forEach(function(L){
                var s = (L || '').trim();
                if (!s) return;
                // Quitar adornos a la derecha (tomar solo el nombre antes de " · ")
               var ix = s.indexOf(' · ');
                var courseName = (ix >= 0) ? s.substring(0, ix) : s;
                courseName = cleanCourseName(courseName);
                lines.push(joinCSVLine(['✔', courseName]));
              });
        
              // separador entre bloques
              lines.push('');
            }
          }
        }catch(_e){}

      var nameEl = document.querySelector('#studentDetailCapture .detail-grid strong');
      var stu  = (nameEl && nameEl.textContent) ? nameEl.textContent.trim() : 'etudiant';
      var slug = stu.replace(/[^\w\-]+/g,'_');
      var d = new Date(), y=d.getFullYear(), m=('0'+(d.getMonth()+1)).slice(-2), day=('0'+d.getDate()).slice(-2);
      var fileName = 'Degree_audit_' + slug + '_' + y + m + day + '.csv';

      download(fileName, csvSepHint() + lines.join('\n'));
      return;
    }

    // 3) MATRIZ: reordenar columnas
    var el = document.getElementById('csvData');
    var raw = (el && el.textContent) ? el.textContent : '';
    if(!raw){ alert('Aucun contenu CSV.'); return; }

    var rows = [];
    (function(){
      var line='', inQ=false;
      for (var ch of raw){
        if (ch === '"'){ inQ = !inQ; line += ch; }
        else if (ch === '\n' && !inQ){ rows.push(line); line=''; }
        else { line += ch; }
      }
      if (line) rows.push(line);
    })();
    if (!rows.length){ alert('CSV vide.'); return; }

    var header = splitCSVLine(rows[0]);
    var headerLower = header.map(function(h){ return (h||'').toLowerCase(); });
    function findIdxCI(names){
      for (var i=0;i<names.length;i++){
        var idx = headerLower.indexOf((names[i]||'').toLowerCase());
        if (idx >= 0) return idx;
      }
      return -1;
    }

    var idxFirstH = findIdxCI(['Prénom']);
    var idxLastH  = findIdxCI(['Nom']);
    var idxEtH    = findIdxCI(['Étudiant']);
    var idxEmail  = findIdxCI(['Email']);
    var idxIdCt   = findIdxCI(['ID Contact','ID_Contact__c','ContactExternalId']);
    var idxManq   = findIdxCI(['Manquants','MANQUANTS']);
    var idxPct    = findIdxCI(['% Avancement','AVANCEMENT','% AVANCEMENT']);
    var idxDern   = findIdxCI(['Dernier cours','DERNIER COURS']);
    var idx7ans   = findIdxCI(['7+ ans','7+ ANS']);

    var fixedSet = {};
    [
      'Étudiant','Prénom','Nom','Email','ID Contact','ID_Contact__c','ContactExternalId',
      'Manquants','% Avancement','AVANCEMENT','Dernier cours','7+ ans'
    ].forEach(function(n){ fixedSet[n.toLowerCase()] = true; });

    function getFirstLast(cols){
      var first = '', last = '';
      if (idxFirstH >= 0 || idxLastH >= 0){
        first = (idxFirstH>=0 && cols.length>idxFirstH) ? cols[idxFirstH] : '';
        last  = (idxLastH >=0 && cols.length>idxLastH ) ? cols[idxLastH ] : '';
      } else if (idxEtH >= 0 && cols.length > idxEtH){
        var full = cols[idxEtH] || '';
        var parts = full.trim().split(/\s+/);
        if (parts.length === 1){ first = parts[0]; }
        else if (parts.length > 1){ last = parts.pop(); first = parts.join(' '); }
      }
      return [first, last];
    }

    var reqSelect = document.querySelector('select[id$="reqFilter"]');
    var selectedReqId = reqSelect ? (reqSelect.value || '') : '';
    var reqLabel = '';
    if (reqSelect) {
      var opt = reqSelect.options[reqSelect.selectedIndex];
      reqLabel = opt ? opt.text : '';
    }

    if (selectedReqId){
      var idxReqCol = -1;
      for (var i=0;i<header.length;i++){
        if ((header[i]||'').trim().toLowerCase() === (reqLabel||'').trim().toLowerCase()){
          idxReqCol = i; break;
        }
      }
      var newHeader = ['Prénom','Nom','Email','ID Contact','Manquants','% Avancement','Dernier cours','7+ ans', reqLabel];
      var out = [ joinCSVLine(newHeader) ];
      for (var r=1; r<rows.length; r++){
        var cols = splitCSVLine(rows[r]); if (!cols.length) continue;
        var fl    = getFirstLast(cols);
        var email = (idxEmail>=0 && cols.length>idxEmail) ? cols[idxEmail] : '';
        var idc   = (idxIdCt>=0 && cols.length>idxIdCt)   ? cols[idxIdCt]   : '';
        var manq  = (idxManq>=0 && cols.length>idxManq)   ? cols[idxManq]   : '';
        var pct   = (idxPct >=0 && cols.length>idxPct )   ? cols[idxPct ]   : '';
        var derr  = (idxDern>=0 && cols.length>idxDern)   ? cols[idxDern]   : '';
        var y7    = (idx7ans>=0 && cols.length>idx7ans)   ? cols[idx7ans]   : '';
        var reqv  = (idxReqCol>=0 && cols.length>idxReqCol)? cols[idxReqCol] : '';
        out.push(joinCSVLine([fl[0], fl[1], email, idc, manq, pct, derr, y7, reqv]));
      }
      download('Degree_audit_matrice_filtre.csv', csvSepHint() + out.join('\n'));
      return;
    }

    var reqLabels = [], reqIndices = [];
    for (var i=0;i<header.length;i++){
      var name = header[i] || '';
      if (!fixedSet[name.toLowerCase()]){
        reqLabels.push(name);
        reqIndices.push(i);
      }
    }
    var newHeader = ['Prénom','Nom','Email','ID Contact','Manquants','% Avancement','Dernier cours','7+ ans'].concat(reqLabels);
    var out = [ joinCSVLine(newHeader) ];
    for (var r=1; r<rows.length; r++){
      var cols = splitCSVLine(rows[r]); if (!cols.length) continue;
      var fl    = getFirstLast(cols);
      var email = (idxEmail>=0 && cols.length>idxEmail) ? cols[idxEmail] : '';
      var idc   = (idxIdCt>=0 && cols.length>idxIdCt)   ? cols[idxIdCt]   : '';
      var manq  = (idxManq>=0 && cols.length>idxManq)   ? cols[idxManq]   : '';
      var pct   = (idxPct >=0 && cols.length>idxPct )   ? cols[idxPct ]   : '';
      var derr  = (idxDern>=0 && cols.length>idxDern)   ? cols[idxDern]   : '';
      var y7    = (idx7ans>=0 && cols.length>idx7ans)   ? cols[idx7ans]   : '';
      var reqVals = reqIndices.map(function(i){ return (cols.length>i) ? cols[i] : ''; });
      out.push(joinCSVLine([fl[0], fl[1], email, idc, manq, pct, derr, y7].concat(reqVals)));
    }
    download('Degree_audit_matrice.csv', csvSepHint() + out.join('\n'));

  }catch(err){
    console.error(err);
    alert('Erreur lors de la génération du CSV. Voir la console (F12).');
  }
}

