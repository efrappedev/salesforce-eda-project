<script>
  // === Modal helpers (déjalos igual) ===
  function openModal(){
      var ov = document.getElementById('modalOverlay');
      var pn = document.getElementById('modalPanel');
      if (ov) ov.style.display = 'block';
      if (pn) pn.style.display = 'block';
      document.body.classList.add('modal-open');
    
      // NUEVO: pintar bloques optativos dentro del modal
      try { buildStudentOptionalBlocks(); } catch(e){}
    }
  function closeModal(){
        try { if (typeof closeDetail === 'function') closeDetail(); } catch(e){}
        var ov = document.getElementById('modalOverlay');
        var pn = document.getElementById('modalPanel');
        if (ov) ov.style.display = 'none';
        if (pn) pn.style.display = 'none';
        document.body.classList.remove('modal-open');
      }
  
  function buildStudentOptionalBlocks(){
          try{
            // tbody de la tabla del modal
            var tbody = document.getElementById('detailTbody') || document.querySelector('#detailTable tbody');
            if (!tbody) return;
        
            // Limpia inyecciones previas
            Array.from(tbody.querySelectorAll('.js-opt-row')).forEach(function(tr){ tr.parentNode.removeChild(tr); });
        
            // Si no hay columnas optativas visibles en la matriz, salimos
            var optHeaders = document.querySelectorAll('.da-table thead th[data-opt="1"]');
            if (!optHeaders.length) return;
        
            // Nombre del alumno
            var nameEl = document.querySelector('#studentDetailCapture .detail-grid strong');
            var modalName = nameEl ? nameEl.textContent.trim() : '';
            if (!modalName) return;
        
            // Busca la fila del alumno en la matriz
            var rows = document.querySelectorAll('.da-table tbody tr');
            var rowDom = null;
            for (var i=0; i<rows.length; i++){
              var a = rows[i].querySelector('.student-name a, .da-col-student a');
              if (a && a.textContent.trim() === modalName){ rowDom = rows[i]; break; }
            }
            if (!rowDom) return;
        
            var optCells = rowDom.querySelectorAll('td[data-opt="1"]');
        
            // Recorre cada bloque optativo y lo inserta al final del tbody
            for (var k=0; k<Math.min(optHeaders.length, optCells.length); k++){
              var th = optHeaders[k];
              var td = optCells[k];
        
              // --- Título limpio del bloque como en el encabezado ---
              var title = (function(th){
                if (!th) return '';
                var base = (th.childNodes && th.childNodes[0] && th.childNodes[0].nodeType === 3)
                  ? (th.childNodes[0].nodeValue || '').trim()
                  : ((th.textContent || '').split('\n')[0] || '').trim();
                base = base.replace(/\s*\(.*?\)\s*$/, '');
                var muted = th.querySelector('.muted');
                var credits = muted ? (muted.textContent || '').trim() : '';
                return credits ? (base + ' ' + credits) : base;
              })(th);
        
              var sub = document.createElement('tr');
              sub.className = 'opt-sub js-opt-row';
              var thSub = document.createElement('th');
              thSub.colSpan = 2;
              thSub.textContent = title;
              sub.appendChild(thSub);
              tbody.appendChild(sub);
        
              // ===== Cursos que aportan créditos (desde el tooltip del td) =====
                var ttl = td.getAttribute('title') || '';
                var courses = parseOptTooltip(ttl);  // ⬅️ reutiliza el mismo parser del popover
                
                courses.forEach(function(course){
                  var tr = document.createElement('tr');
                  tr.className = 'js-opt-row';
                
                  var td1 = document.createElement('td');
                  td1.style.textAlign = 'center';
                  td1.className = 'ico ok';
                  td1.innerHTML = '&#10003;';
                
                  var td2 = document.createElement('td');
                  td2.textContent = course;
                
                  tr.appendChild(td1);
                  tr.appendChild(td2);
                  tbody.appendChild(tr);
                });
            }
          }catch(e){
            console.warn('buildStudentOptionalBlocks error', e);
          }
        }
 
  /* === NUEVO: convertir <img id="pdfLogo"> a DataURL para dibujarlo en el PDF === */
  async function getLogoDataUrl(){
    try{
      const img = document.getElementById('pdfLogo');
      if (!img) return null;

      // Esperar carga si hiciera falta
      if (!img.complete || img.naturalWidth === 0){
        await new Promise(res => {
          img.onload = () => res();
          img.onerror = () => res();
        });
      }

      const c = document.createElement('canvas');
      c.width  = img.naturalWidth || 300;
      c.height = img.naturalHeight || 80;
      const ctx = c.getContext('2d');
      ctx.drawImage(img, 0, 0, c.width, c.height);
      return c.toDataURL('image/png');
    }catch(e){
      console.warn('getLogoDataUrl error', e);
      return null;
    }
  }

      // === PDF inteligente (detalle vs matriz) — ahora añade el logo en cada página ===
        async function exportPdfSmart(){
          try{
            const { jsPDF } = window.jspdf;
            const pdf = new jsPDF({ unit: 'pt', format: 'a4' });
        
            // --- prepara el logo (dataURL)
            const logoDataUrl = await getLogoDataUrl();
        
            // ¿modal (detalle) o matriz principal?
            const modalOpen = !!(document.getElementById('studentDetailCapture'));
            const target = modalOpen
              ? document.getElementById('studentDetailCapture')
              : document.getElementById('daTableWrap');
        
            if (!target){ alert('Aucun contenu à exporter.'); return; }
        
            // Márgenes/medidas
            const marginX = 40, topFirst = 80, topNext = 40, bottom = 40;
            const pageW = pdf.internal.pageSize.getWidth();
            const pageH = pdf.internal.pageSize.getHeight();
            const usableWpt = pageW - marginX * 2;
        
            // Render a canvas
            const SCALE = 2.6;
            const canvas = await html2canvas(target, {
              scale: SCALE, backgroundColor:'#ffffff', useCORS:true, letterRendering:true
            });
        
            // Conversión px → pt y alturas disponibles
            const ptPerPx = usableWpt / canvas.width;
            const availFirstPt = pageH - topFirst - bottom;
            const availNextPt  = pageH - topNext  - bottom;
            const availFirstPx = Math.floor(availFirstPt / ptPerPx);
            const availNextPx  = Math.floor(availNextPt  / ptPerPx);
        
            // Canvas temporal para “rebanadas”
            const tmp = document.createElement('canvas');
            const ctx = tmp.getContext('2d', { willReadFrequently: true });
            ctx.imageSmoothingEnabled = false;
            ctx.imageSmoothingQuality = 'high';
        
            // ——— Logo SOLO en la página 1 ———
            function drawLogoOnceOnFirstPage(){
              if (!logoDataUrl) return;
              const logoW = 120, logoH = 32;  // ajusta si quieres
              const logoX = marginX, logoY = 16;
              pdf.addImage(logoDataUrl, 'PNG', logoX, logoY, logoW, logoH);
            }
            drawLogoOnceOnFirstPage(); // ← una sola vez, antes del bucle
        
            // ——— Paginado ———
            let sy = 0;
            let first = true;
        
            while (sy < canvas.height) {
              const slicePx = first ? availFirstPx : availNextPx;
              const hPx = Math.min(slicePx, canvas.height - sy);
        
              tmp.width  = canvas.width;
              tmp.height = hPx;
              ctx.clearRect(0,0,tmp.width,tmp.height);
              ctx.drawImage(canvas, 0, sy, canvas.width, hPx, 0, 0, tmp.width, hPx);
        
              const dataUrl = tmp.toDataURL('image/jpeg', 0.70);
              const targetHpt = hPx * ptPerPx;
        
              pdf.addImage(
                dataUrl, 'JPEG',
                marginX, first ? topFirst : topNext,
                usableWpt, targetHpt, undefined, 'FAST'
              );
        
              sy += hPx;
              first = false;
        
              if (sy < canvas.height) {
                pdf.addPage();  // páginas siguientes SIN logo
                // (no vuelvas a llamar al logo aquí)
              }
            }
        
            // Nombre del archivo
            let nameBase = 'Degree_audit';
            if (modalOpen){
              const nameEl = document.querySelector('#studentDetailCapture .detail-grid strong');
              if (nameEl && nameEl.textContent) nameBase += '_' + nameEl.textContent.trim().replace(/\s+/g,'_');
            } else {
              const reqSelect = document.querySelector('select[id$="reqFilter"]');
              if (reqSelect && reqSelect.value){
                const txt = reqSelect.options[reqSelect.selectedIndex]?.text || 'filtre';
                nameBase += '_' + txt.replace(/\s+/g,'_');
              } else {
                nameBase += '_matrice';
              }
            }
            const d = new Date(), y=d.getFullYear(), m=('0'+(d.getMonth()+1)).slice(-2), day=('0'+d.getDate()).slice(-2);
            pdf.save(`${nameBase}_${y}${m}${day}.pdf`);
        
          }catch(e){
            console.error(e);
            alert('Impossible de générer le PDF. Voir la console (F12).');
          }
        }

</script>

  <script>
    /* Inicializa ripple para <input class="da-btn|da-btn-secondary"> */
    function initBtnRipple(){
      try{
        var sel = 'input.da-btn, input.da-btn-secondary';
        document.querySelectorAll(sel).forEach(function(btn){
          if (btn.closest('.btn-visual')) return;
          var wrap = document.createElement('span');
          wrap.className = 'btn-visual';
          btn.parentNode.insertBefore(wrap, btn);
          wrap.appendChild(btn);
          wrap.addEventListener('mouseenter', function(){ wrap.classList.add('hover'); });
          wrap.addEventListener('mouseleave', function(){ wrap.classList.remove('hover'); wrap.classList.remove('pressed'); });
          wrap.addEventListener('mousedown', function(){ wrap.classList.add('pressed'); });
          wrap.addEventListener('mouseup', function(){ wrap.classList.remove('pressed'); });
          wrap.addEventListener('keydown', function(e){ if(e.key===' '||e.key==='Enter'){ wrap.classList.add('pressed'); }});
          wrap.addEventListener('keyup', function(){ wrap.classList.remove('pressed'); });
        });
      }catch(e){ console.warn('initBtnRipple error', e); }
    }
    window.addEventListener('load', initBtnRipple);
    </script>

<script>
  function openContactRecord(id){
    try{
      var origin = window.location.origin || '';
      var path   = window.location.pathname || '';
      // Si es Experience Cloud, conserva el prefijo del sitio (antes de '/s/')
      var sitePrefix = (path.indexOf('/s/') > -1) ? path.split('/s/')[0] : '';
      var url = origin + sitePrefix + '/lightning/r/Contact/' + id + '/view';
      window.open(url, '_blank', 'noopener');
    }catch(e){
      // Fallback absoluto
      window.open('/' + id, '_blank', 'noopener');
    }
  }
</script>


