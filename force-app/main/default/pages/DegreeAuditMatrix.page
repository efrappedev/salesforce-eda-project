</script>

  <!-- ==================== Sticky & Sorting ==================== -->
  <script>
    function applyStickyOffsets(){
            try {
                var wrap  = document.getElementById('daTableWrap');
                var table = document.querySelector('.da-table');
                if(!wrap || !table) return;

                let parent = wrap.parentElement;
                if (parent) parent.style.overflow = 'visible';
                let grandparent = parent ? parent.parentElement : null;
                if (grandparent) grandparent.style.overflow = 'visible';
                
                var thIdx = table.querySelector('thead th.da-col-idx');
                var thStu = table.querySelector('thead th.da-col-student');
                if(!(thIdx && thStu)) return;

                var leftStudent = Math.round(thIdx.getBoundingClientRect().width);
                var leftEmail   = Math.round(leftStudent + thStu.getBoundingClientRect().width);

                wrap.style.setProperty('--left-student', leftStudent + 'px');
                wrap.style.setProperty('--left-email',   leftEmail   + 'px');
            } catch(e) { console.warn('applyStickyOffsets error', e); }
        }
        
        // ======================= FUNCIÓN FINAL Y CORRECTA =======================
        function initStickyStabilizer() {
            const wrap = document.querySelector('.da-table-wrap');
            if (!wrap) return;
            
            if (wrap.dataset.stabilizerAttached) return;

            let ticking = false;
            wrap.addEventListener('scroll', function(e) {
                if (!ticking) {
                    window.requestAnimationFrame(function() {
                        const stickyElements = wrap.querySelectorAll('thead th, tbody .da-col-idx, tbody .da-col-student, tbody .da-col-email');
                        stickyElements.forEach(el => {
                            el.style.transform = 'translateZ(0)';
                        });
                        ticking = false;
                    });
                    ticking = true;
                }
            });
            wrap.dataset.stabilizerAttached = 'true';
        }

            function initTableSorters(){
              var table = document.querySelector('.da-table');
              if(!table || !table.tHead || !table.tBodies.length) return;
        
              var ths = table.tHead.rows[0].cells;
              for (var i=0;i<ths.length;i++){
                var th = ths[i];
                if (!th.classList.contains('sortable')) continue;
        
                th.onclick = null;
                th.onkeydown = null;
        
                th.setAttribute('title','Cliquez pour trier');
                th.setAttribute('tabindex','0');
                th.setAttribute('role','button');
        
                th.onkeydown = function(e){
                  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this.click(); }
                };
        
                th.onclick = (function(th){
                  return function(){
                    var table = th.closest('table');
                    var idx   = th.cellIndex;
                    var type  = th.getAttribute('data-type') || 'text';
                    var dir   = th.classList.contains('sort-asc') ? 'desc' : 'asc';
        
                    Array.prototype.forEach.call(th.parentNode.children, function(h){
                      h.classList.remove('sort-asc','sort-desc');
                    });
                    th.classList.add(dir === 'asc' ? 'sort-asc' : 'sort-desc');
        
                    sortTableBy(table, idx, type, dir);
                  };
                })(th);
              }
            }
        
            function sortTableBy(table, colIndex, type, dir){
              var tbody = table.tBodies[0];
              var rows = Array.prototype.slice.call(tbody.rows);
              var mult = (dir === 'desc') ? -1 : 1;
        
              rows.sort(function(a,b){
                var va = getCellVal(a.cells[colIndex], type);
                var vb = getCellVal(b.cells[colIndex], type);
        
                if (va == null && vb == null) return 0;
                if (va == null) return -1 * mult;
                if (vb == null) return  1 * mult;
        
                if (typeof va === 'number' && typeof vb === 'number'){
                  return (va - vb) * mult;
                }
                va = String(va).toLowerCase();
                vb = String(vb).toLowerCase();
                return (va < vb ? -1 : va > vb ? 1 : 0) * mult;
              });
        
              rows.forEach(function(r){ tbody.appendChild(r); });
              renumberRows(tbody);
            }
        
            function getCellVal(td, type){
              if (!td) return null;
              var txt = (td.textContent || '').trim();
        
              switch(type){
                case 'num':
                  var m = txt.match(/-?\d+(?:\.\d+)?/);
                  return m ? parseFloat(m[0]) : null;
                case 'date':
                  if (!txt) return null;
                  var t = Date.parse(txt);
                  return isNaN(t) ? null : t;
                case 'bool':
                  if (td.querySelector('.ico.ok'))   return 1;
                  if (td.querySelector('.ico.miss')) return 0;
                  if (/[✓✔]/.test(txt)) return 1;
                  if (/[✗✖]/.test(txt)) return 0;
                  return 0;
                case 'bool7':
                  if (td.querySelector('.ico.miss')) return 1;
                  if (td.querySelector('.ico.ok'))   return 0;
                  if (/[⛔]/.test(txt)) return 1;
                  if (/[✅]/.test(txt)) return 0;
                  return 0;
                default:
                  return txt;
              }
            }
        
            function renumberRows(tbody){
              var n = 1;
              Array.prototype.forEach.call(tbody.rows, function(tr){
                var idxCell = tr.querySelector('td.da-col-idx');
                if (idxCell) idxCell.textContent = n++;
              });
            }
        
            function wireUpUI(){
              try{ applyStickyOffsets(); }catch(e){}
              try{ initTableSorters(); }catch(e){}
              try{ sanitizeOptTitles(); }catch(e){}          
              try{ initOptBlockClickReveal(); }catch(e){}     
            }

        // Mostrar “Tous” en ambos combos al cargar (solo UI)
        function forceToolbarDefaults(){
          try{
            var selPlan = document.querySelector('select[id$="planStatus"]');
            if (selPlan) selPlan.value = 'Current';

            var selPe = document.querySelector('select[id$="peStatus"]');
            if (selPe) selPe.value = 'Current';
        
            var req = document.querySelector('select[id$="reqFilter"]');
            if (req) req.value = '';  // deja el placeholder seleccionado
          }catch(e){}
        }

        window.addEventListener('load', function(){
          forceToolbarDefaults();
          setTimeout(wireUpUI,0);
        });
        
        // Recalcular offsets cuando cambie el ancho de la página/viewport
        let _rzTO;
        window.addEventListener('resize', function(){
          clearTimeout(_rzTO);
          _rzTO = setTimeout(applyStickyOffsets, 60);
        });
        
        // Observar cambios de tamaño del contenedor
        const wrap = document.getElementById('daTableWrap');
        if (wrap && 'ResizeObserver' in window){
          const ro = new ResizeObserver(() => applyStickyOffsets());
          ro.observe(wrap);
        }

  </script>

